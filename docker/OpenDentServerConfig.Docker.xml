<?xml version="1.0"?>
<!--
  OpenDentalServer config for Docker Compose.
  The MySQL host is "mysql" (the Compose service name) instead of "localhost".
  Mount this file over /app/OpenDentServerConfig.xml in the container,
  or rebuild the image after updating credentials.

  SECURITY NOTE: Do not commit real passwords to version control.
  Rotate these credentials before deploying to any non-development environment.
-->
<ConnectionSettings>
  <ServerPort>9390</ServerPort>
  <DatabaseConnection>
    <ComputerName>mysql</ComputerName>
    <Database>opendental</Database>
    <User>oduser</User>
    <Password>odpass</Password>
    <UserLow>oduser</UserLow>
    <PasswordLow>odpass</PasswordLow>
  </DatabaseConnection>
</ConnectionSettings>
